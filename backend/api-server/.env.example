# ===== 런타임 / CORS =====
NODE_ENV=local
VERSION=1.0.0
WEB_ORIGIN=http://localhost:5173

# ===== 기능 스위치 =====
# DB 읽어서 컨텐츠/정책 사용 (true 권장)
FEATURE_USE_DB=true

# ===== 썸네일 저장소 선택 =====
# LOCAL 또는 S3 중 하나만!
STORE_MODE=S3
AWS_REGION=ap-northeast-2
S3_BUCKET=youth-policy-thumbnails-kch
S3_PREFIX=thumbnails

# S3 사용 시 필수 (IAM 사용자 Access Key/Secret)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ===== LLM =====
OPENAI_API_KEY=sk-xxxxxx

# ===== 외부 API =====
YOUTHCENTER_API_KEY=
PAGE_SIZE=10
MAX_PAGES=10

# ===== DB =====
DATABASE_URL=postgresql+psycopg2://postgres:비밀번호@3.35.233.83:5432/youth_policy
DB_URL=postgresql+psycopg2://postgres:비밀번호@3.35.233.83:5432/youth_policy

# ===== 내부 API 키 (관리자용) =====
API_KEY=