{
  "name": "blog-platform-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend/*"
  ],
  "scripts": {
    "dev:web": "cd frontend/web-client && yarn dev",
    "build:web": "cd frontend/web-client && yarn build",
    "preview:web": "cd frontend/web-client && yarn preview",
    "lint:web": "cd frontend/web-client && yarn lint",
    "dev:api": "cd backend/api-server && uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "format": "prettier --write \"frontend/**/*.{js,jsx,ts,tsx,json,md}\"",
    "clean": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && find . -name 'dist' -type d -prune -exec rm -rf '{}' + && find . -name '__pycache__' -type d -prune -exec rm -rf '{}' + && find . -name '.pytest_cache' -type d -prune -exec rm -rf '{}' +"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  },
  "packageManager": "yarn@1.22.22"
}